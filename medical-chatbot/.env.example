# Medical AI Chatbot - Environment Configuration
# Copy this file to .env and update the values as needed

# ============================================
# Backend Services Configuration
# ============================================

# Ollama API Configuration
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=qwen2
MEDICAL_MODEL_NAME=meditron:latest

# Database Configuration
VECTOR_DB_PATH=./data/vector_db

# ============================================
# Streamlit Configuration
# ============================================

# API Base URL (for Streamlit GUI)
API_BASE_URL=http://localhost:8000

# ============================================
# FastAPI Configuration
# ============================================

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# Optional: Advanced Settings
# ============================================

# Request timeout (in seconds)
REQUEST_TIMEOUT=60

# Maximum tokens for LLM response
MAX_TOKENS=512

# Temperature for LLM (0.0 - 1.0)
# Lower = more deterministic, Higher = more creative
TEMPERATURE=0.3

# Number of retrieved documents for RAG
SIMILAR_DOCS_LIMIT=3

# ============================================
# Docker Configuration (if using containers)
# ============================================

# Docker network
DOCKER_NETWORK=medical-network

# Docker service names
OLLAMA_SERVICE=ollama
BACKEND_SERVICE=backend
STREAMLIT_SERVICE=streamlit
